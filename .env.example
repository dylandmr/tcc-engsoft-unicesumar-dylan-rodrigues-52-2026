# Prompt Arena — environment configuration.
# Copy to `.env` (git-ignored) and fill in the providers you want to exercise.
# Keys are used SERVER-SIDE only and are never exposed to the browser.
# A provider with no key is treated as unavailable and surfaces a per-provider error.

# OpenAI ChatGPT
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=

# xAI Grok (OpenAI-compatible, base https://api.x.ai/v1)
XAI_API_KEY=
XAI_MODEL=

# DeepSeek (OpenAI-compatible, base https://api.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# Tunable limits (optional; prototype defaults applied if unset)
# MAX_PROMPT_LEN=8000
# PROVIDER_TIMEOUT_MS=45000
